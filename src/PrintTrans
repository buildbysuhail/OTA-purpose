        string GetFormatedValues(string Value, string Format)
        {
            string t = "";
            string ws = "                                                                                                                                                                                                                                                              ";
            ws += ws; ws += ws; ws += ws;
            if (FldFont == PolosysFrameWork.General.QRCode_Font) return Value;
            if (FldFont == PolosysFrameWork.General.QRCode_Font2) return Value;

            if (Format.IndexOf("#", 0) > -1 && Format.IndexOf("**", 0) == -1)
            {
               
                t = Convert.ToDouble(PolosysFrameWork.General.Val(Value)).ToString(Format);
            }
            else if (Format.ToUpper() == "QTY")
            {
                t = Convert.ToDouble(PolosysFrameWork.General.Val(Value)).ToString("###0");
                
            }
            else if (Format.ToUpper() == "QTY1")
            {
                double t1 = Convert.ToDouble(PolosysFrameWork.General.Val(Value));
                long t2 = Convert.ToInt64(PolosysFrameWork.General.Val(Value));

                if(t1!=Convert.ToDouble(t2))
                {
                    //precison is available
                    t = Convert.ToDouble(PolosysFrameWork.General.Val(Value)).ToString("###0.0");

                }
                else
                {
                    //precison is available
                    t = Convert.ToDouble(PolosysFrameWork.General.Val(Value)).ToString("###0");
                }

            }
            else if (Format.ToUpper() == "QTY2")
            {
                double t1 = Convert.ToDouble(PolosysFrameWork.General.Val(Value));
                long t2 = Convert.ToInt64(PolosysFrameWork.General.Val(Value));

                if (t1 != Convert.ToDouble(t2))
                {
                    //precison is available
                    t = Convert.ToDouble(PolosysFrameWork.General.Val(Value)).ToString("###0.00");

                }
                else
                {
                    //precison is available
                    t = Convert.ToDouble(PolosysFrameWork.General.Val(Value)).ToString("###0");
                }

            }
            else if (Format.ToUpper() == "QTY3")
            {
                double t1 = Convert.ToDouble(PolosysFrameWork.General.Val(Value));
                long t2 = Convert.ToInt64(PolosysFrameWork.General.Val(Value));

                if (t1 != Convert.ToDouble(t2))
                {
                    //precison is available
                    t = Convert.ToDouble(PolosysFrameWork.General.Val(Value)).ToString("###0.000");

                }
                else
                {
                    //precison is available
                    t = Convert.ToDouble(PolosysFrameWork.General.Val(Value)).ToString("###0");
                }

            }
            else if (Format.ToUpper() == "AR_NUM")
            {
                t = Convert.ToDouble(PolosysFrameWork.General.Val(Value)).ToString("###0");
                t = PolosysFrameWork.General.GetArabicNumber(t);
            }
            else if (Format.ToUpper() == "SHRINK")
            {
              t = Value;
            }
            else if (Format.ToUpper() == "AR_DIG2")
            {
                t = Convert.ToDouble(PolosysFrameWork.General.Val(Value)).ToString("###0.00");
                t = PolosysFrameWork.General.GetArabicNumber(t);
            }


            else if (Format.ToUpper() == "AR_DATE")
            {
                t = TransDate.ToString("dd-MM-yyyy", CultureInfo.InvariantCulture);
                t = PolosysFrameWork.General.GetArabicDateNumer(t);
            }

            else if (Format.ToUpper() == "AR_DIG3")
            {
                t = Convert.ToDouble(PolosysFrameWork.General.Val(Value)).ToString("###0.000");
                t = PolosysFrameWork.General.GetArabicNumber(t);
            }
            else if (Format.IndexOf("d", 0) > -1 || Format.IndexOf("M", 0) > -1 || Format.IndexOf("y", 0) > -1)
            {
                t = Convert.ToDateTime(Value).ToString(Format);
            }
            else if (Format.IndexOf("H", 0) > -1 || Format.IndexOf("h", 0) > -1 || Format.IndexOf("m", 0) > -1 || Format.IndexOf("s", 0) > -1)
            {
                t = Convert.ToDateTime(Value).ToString(Format);
            }
            else if (Format.ToUpper() == "NONE")
            {
                t = Value;
            }
            
            else if (Format.ToUpper() == "BIZ")
            {
                t = (Convert.ToDouble(PolosysFrameWork.General.Val(Value)) == 0) ? "" : Convert.ToDouble(PolosysFrameWork.General.Val(Value)).ToString("###0.00");
            }
         
            else
            {
                t = Value;
            }

            if (FldAlign == "Left")
            {
                t = t + ws;
                t = t.Substring(0, Convert.ToInt32(FldLength));
            }
            else if (FldAlign == "Right")
            {
                t = ws + t;
                t = t.Substring(t.Length - Convert.ToInt32(FldLength));
            }
            else if (FldAlign == "Right Justify")
            {
                t = ws + t;
                t = t.Substring(t.Length - Convert.ToInt32(FldLength));
            }
            else if (FldAlign == "Center")
            {
                t = ws + t + ws;
                t = t.Substring((t.Length / 2 - Convert.ToInt32(FldLength) / 2), Convert.ToInt32(FldLength) / 2);
            }
            else
            {
                try
                {
                    t = t + ws;
                    t = t.Substring(0, Convert.ToInt32(FldLength));
                }catch(Exception ex) { }
            }
            return t;

        }
