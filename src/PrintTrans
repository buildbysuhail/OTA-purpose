        string GetFieldValue(bool IsDetailSection = false, int DetailsRow = 0)
         {
            string FieldVal = "";
            //bool lastWasGatePass = false;
            try
            {
                if (IsDetailSection == false)
                {
                    for (int j = 0; j < dtTranMaster.Columns.Count; j++)
                    {
                        if (FldName.ToUpper().Trim() == dtTranMaster.Columns[j].ColumnName.ToUpper().Trim())
                        {
                            FieldVal = dtTranMaster.Rows[0][j].ToString();
                            return GetFormatedValues(FieldVal, FldFormat);
                        }
                    }
                    FieldVal = GetCommonValues(FldName);
                    return GetFormatedValues(FieldVal, FldFormat);
                }
                else
                {
                    for (int j = 0; j < dtTransDetails.Columns.Count; j++)
                    {
                        if (FldName.ToUpper().Trim() == dtTransDetails.Columns[j].ColumnName.ToUpper().Trim())
                        {
                            #region Whene ProductDescription adding time
                            if (FldName == "ProductDescription" && PolosysFrameWork.General.IS_APP_GLOBAL)
                            {
                                string prds = dtTransDetails.Rows[DetailsRow][j].ToString();
                                

                                if (!string.IsNullOrEmpty(prds))
                                {
                                    string[] dimensions = prds.Split(',');

                                    int maxCharLength = 25;
                                    System.Text.StringBuilder currentLine = new System.Text.StringBuilder();

                                    List<string> groupedLines = new List<string>();

                                    foreach (string dimension in dimensions)
                                    {
                                        string trimmedDimension = dimension.Trim();
                                        if ((currentLine.Length + trimmedDimension.Length + 2) > maxCharLength)
                                        {
                                            groupedLines.Add(currentLine.ToString().TrimEnd(','));
                                            currentLine.Clear();
                                        }
                                        currentLine.Append(trimmedDimension + ", ");
                                    }
                                    if (currentLine.Length > 0)
                                    {
                                        groupedLines.Add(currentLine.ToString().TrimEnd(','));
                                    }
                                    FieldVal = string.Join(Environment.NewLine, groupedLines);
                                }
                                else
                                {
                                    FieldVal = prds;
                                }
                                return GetFormatedValues(FieldVal, FldFormat);
                                
                            }
                            #endregion
                            else
                            {
                                FieldVal = dtTransDetails.Rows[DetailsRow][j].ToString();
                                return GetFormatedValues(FieldVal, FldFormat);
                                
                            }
                        }
                    }
                    //if not found in details
                    for (int j = 0; j < dtTranMaster.Columns.Count; j++)
                    {
                        if (FldName.ToUpper().Trim() == dtTranMaster.Columns[j].ColumnName.ToUpper().Trim())
                        {
                            FieldVal = dtTranMaster.Rows[0][j].ToString();
                            return GetFormatedValues(FieldVal, FldFormat);
                        }
                    }

                }
            }
            catch (Exception ex) { }
            FieldVal = GetCommonValues(FldName);
            return GetFormatedValues(FieldVal, FldFormat);

        }
