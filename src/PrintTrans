        void ReadSettingsFiles()
        {
            Ln = SR.ReadLine();//"<START IH>"
            
            IHSettings = "";
            do
            {//Read Invoice Header
                Ln = SR.ReadLine();
                if (Ln.Trim() != "<STOP IH>") IHSettings += Ln + "~";
            } while (Ln.Trim() != "<STOP IH>");

            Ln = SR.ReadLine();//"<START PH>"
            PHSettings = "";
            do
            {//Read Page Header
                Ln = SR.ReadLine();
                if (Ln.Trim() != "<STOP PH>") PHSettings += Ln + "~";
            } while (Ln.Trim() != "<STOP PH>");

            Ln = SR.ReadLine();//"<START DT>"
            DTSettings = "";
            do
            {//Read Details Header
                Ln = SR.ReadLine();

                if (Ln.Trim() != "<STOP DT>") DTSettings += Ln + "~";
            } while (Ln.Trim() != "<STOP DT>");



            Ln = SR.ReadLine();//"<START PF>"
            PFSettings = "";
            do
            {//Read Details Header
                Ln = SR.ReadLine();
                if (Ln.Trim() != "<STOP PF>") PFSettings += Ln + "~";
            } while (Ln.Trim() != "<STOP PF>");

            Ln = SR.ReadLine();//"<START IF>"
            IFSettings = "";
            do
            {//Read Invoice Footer
                Ln = SR.ReadLine();
                if (Ln.Trim() != "<STOP IF>") IFSettings += Ln + "~";
            } while (Ln.Trim() != "<STOP IF>");

            SR.Close();
        }
