        public void SaveAsPdf(string path = "")
        {
            try
            {
                var sfd = new SaveFileDialog();
                sfd.Title = "Save As PDF";
                sfd.Filter = "(*.pdf)|*.pdf";
                sfd.InitialDirectory = $@"{AppDomain.CurrentDomain.BaseDirectory}";
                if (path == "")
                {
                    if (sfd.ShowDialog() == DialogResult.OK)
                    {

                        PD.PrinterSettings = new PrinterSettings()
                        {
                            PrinterName = "Microsoft Print to PDF",
                            PrintToFile = true,
                            PrintFileName = Path.Combine(sfd.FileName + ".pdf"),
                        };
                    }
                }
                else
                {
                    PD.PrinterSettings = new PrinterSettings()
                    {

                        PrinterName = "Microsoft Print to PDF",
                        PrintToFile = true,
                        PrintFileName = path,
                    };
                }
                try
                {
                    PD.Print();
                    PolosysFrameWork.General.ShowMessageBox("PDF saved successfully.", "Success", MessageBoxButtons.OK, MessageBoxIcon.Information);
                }
                catch (Exception ex)
                {
                    PolosysFrameWork.General.ShowMessageBox(ex.Message);

                }
            }
            catch (Exception ex)
            {

                PolosysFrameWork.General.ShowMessageBox(ex.Message);
            }
           

        }
        void SelectPaperSize()
        {
            PrinterSettings settings = new PrinterSettings();

            if (PortForm == "[User Defined]")
            {
                PaperSize paperSize = new PaperSize("Polosys Custome Paper", Width, Height);
                paperSize.RawKind = (int)PaperKind.Custom;
                PD.DefaultPageSettings.PaperSize = paperSize;
                return;
            }
            else if (PortForm == "" || PortForm == "[Printer Defaults]")
            {
                return;
            }
            else
            {
                foreach (PaperSize size in settings.PaperSizes)
                {

                    if (size.PaperName == PortForm)
                    {
                        PD.DefaultPageSettings.PaperSize = size;
                        return;
                    }
                }

            }
        }
